
@startuml

left to right direction
skinparam packageStyle rectangle

actor "Visiteur\n(non connecté)" as Visiteur
actor "Administrateur\n(connecté)" as Admin

rectangle "Application Todolist" {
  usecase "Consulter les tâches"    as UC1
  usecase "Créer une tâche"         as UC2
  usecase "Modifier une tâche"      as UC3
  usecase "Supprimer une tâche"     as UC4
  usecase "Marquer comme faite"     as UC5
  usecase "Rechercher une tâche"    as UC6
}

Visiteur --> UC1
Visiteur --> UC6

Admin --> UC1
Admin --> UC2
Admin --> UC3
Admin --> UC4
Admin --> UC5
Admin --> UC6

@enduml